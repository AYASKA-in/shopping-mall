<Window x:Class="ShoppingMall.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShoppingMall.Client.ViewModels"
        xmlns:views="clr-namespace:ShoppingMall.Client.Views"
        xmlns:res="clr-namespace:ShoppingMall.Client.Resources"
        xmlns:conv="clr-namespace:ShoppingMall.Client.Converters"
        x:Name="ThisWindow"
        Title="{x:Static res:Strings.AppTitle}" Height="768" Width="1280"
        WindowState="Maximized" WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI" FontSize="14">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToBrushConverter x:Key="ActiveNavBrush" TrueBrush="#2563EB" FalseBrush="Transparent" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A56DB" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Shopping Mall POS" FontSize="20"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}, ConverterParameter=False}">
                    <Button Content="POS" Command="{Binding NavigateToPosCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsPosView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Inventory" Command="{Binding NavigateToInventoryCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsInventoryView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Products" Command="{Binding NavigateToProductListCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsProductListView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Suppliers" Command="{Binding NavigateToSupplierListCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsSupplierListView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Customers" Command="{Binding NavigateToCustomerCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsCustomerView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Reports" Command="{Binding NavigateToReportsCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsReportsView, Converter={StaticResource ActiveNavBrush}}"/>
                    <Button Content="Admin" Command="{Binding NavigateToAdminCommand}" Style="{StaticResource NavButton}"
                            Foreground="White" Background="{Binding IsAdminView, Converter={StaticResource ActiveNavBrush}}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}, ConverterParameter=False}">
                    <TextBlock Text="{Binding UserDisplayName}" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="Logout" Command="{Binding LogoutCommand}"
                            Foreground="White" Background="Transparent" BorderBrush="White" BorderThickness="1"
                            Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <views:LoginView Grid.Row="1" DataContext="{Binding LoginVM}"
                         Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsLoginView, Converter={StaticResource BoolToVis}}"/>
        <views:PosView Grid.Row="1" DataContext="{Binding PosVM}" 
                       Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsPosView, Converter={StaticResource BoolToVis}}"/>
        <views:ProductListView Grid.Row="1" DataContext="{Binding ProductListVM}"
                               Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsProductListView, Converter={StaticResource BoolToVis}}"/>
        <views:SupplierListView Grid.Row="1" DataContext="{Binding SupplierListVM}"
                                Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsSupplierListView, Converter={StaticResource BoolToVis}}"/>
        <views:CustomerView Grid.Row="1" DataContext="{Binding CustomerVM}"
                             Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsCustomerView, Converter={StaticResource BoolToVis}}"/>
        <views:ReportsView Grid.Row="1" DataContext="{Binding ReportsVM}"
                           Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsReportsView, Converter={StaticResource BoolToVis}}"/>
        <views:AdminView Grid.Row="1" DataContext="{Binding AdminVM}"
                         Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsAdminView, Converter={StaticResource BoolToVis}}"/>
        <views:InventoryView Grid.Row="1" DataContext="{Binding InventoryVM}"
                             Visibility="{Binding ElementName=ThisWindow, Path=DataContext.IsInventoryView, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</Window>
