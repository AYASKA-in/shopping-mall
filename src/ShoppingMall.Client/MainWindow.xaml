<Window x:Class="ShoppingMall.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShoppingMall.Client.ViewModels"
        xmlns:views="clr-namespace:ShoppingMall.Client.Views"
        Title="Shopping Mall POS" Height="768" Width="1280"
        WindowState="Maximized" WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI" FontSize="14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A56DB" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Shopping Mall POS" FontSize="20"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}, ConverterParameter=False}">
                    <Button Content="POS" Command="{Binding NavigateToPosCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Inventory" Command="{Binding NavigateToInventoryCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Products" Command="{Binding NavigateToProductListCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Suppliers" Command="{Binding NavigateToSupplierListCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Customers" Command="{Binding NavigateToCustomerCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Reports" Command="{Binding NavigateToReportsCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                    <Button Content="Admin" Command="{Binding NavigateToAdminCommand}"
                            Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}, ConverterParameter=False}">
                    <TextBlock Text="{Binding UserDisplayName}" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="Logout" Command="{Binding LogoutCommand}"
                            Foreground="White" Background="Transparent" BorderBrush="White" BorderThickness="1"
                            Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <views:LoginView Grid.Row="1" Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}}"/>
        <views:PosView Grid.Row="1" DataContext="{Binding PosVM}" 
                       Visibility="{Binding IsPosView, Converter={StaticResource BoolToVis}}"/>
        <views:ProductListView Grid.Row="1" DataContext="{Binding ProductListVM}"
                               Visibility="{Binding IsProductListView, Converter={StaticResource BoolToVis}}"/>
        <views:SupplierListView Grid.Row="1" DataContext="{Binding SupplierListVM}"
                                Visibility="{Binding IsSupplierListView, Converter={StaticResource BoolToVis}}"/>
        <views:CustomerView Grid.Row="1" DataContext="{Binding CustomerVM}"
                             Visibility="{Binding IsCustomerView, Converter={StaticResource BoolToVis}}"/>
        <views:ReportsView Grid.Row="1" DataContext="{Binding ReportsVM}"
                           Visibility="{Binding IsReportsView, Converter={StaticResource BoolToVis}}"/>
        <views:AdminView Grid.Row="1" DataContext="{Binding AdminVM}"
                         Visibility="{Binding IsAdminView, Converter={StaticResource BoolToVis}}"/>
        <views:InventoryView Grid.Row="1" DataContext="{Binding InventoryVM}"
                             Visibility="{Binding IsInventoryView, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</Window>
