<UserControl x:Class="ShoppingMall.Client.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ShoppingMall.Client.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToBrushConverter x:Key="ActiveTabBrush" TrueBrush="#DBEAFE" FalseBrush="Transparent" />
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A56DB" Padding="10" CornerRadius="5">
            <TextBlock Text="Admin Panel" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Users" Command="{Binding SelectUsersTabCommand}" Padding="12,8" Margin="0,0,3,0"
                    Background="{Binding IsUsersTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="1" Content="Stores" Command="{Binding SelectStoresTabCommand}" Padding="12,8" Margin="3,0"
                    Background="{Binding IsStoresTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="2" Content="Terminals" Command="{Binding SelectTerminalsTabCommand}" Padding="12,8" Margin="3,0"
                    Background="{Binding IsTerminalsTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="3" Content="Config" Command="{Binding SelectConfigTabCommand}" Padding="12,8" Margin="3,0"
                    Background="{Binding IsConfigTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="4" Content="Backups" Command="{Binding SelectBackupsTabCommand}" Padding="12,8" Margin="3,0"
                    Background="{Binding IsBackupsTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="5" Content="Audit Log" Command="{Binding SelectAuditTabCommand}" Padding="12,8" Margin="3,0"
                    Background="{Binding IsAuditTab, Converter={StaticResource ActiveTabBrush}}"/>
            <Button Grid.Column="7" Content="Refresh" Command="{Binding RefreshCommand}" Background="#059669" Foreground="White" Padding="12,8" BorderThickness="0"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid Visibility="{Binding IsUsersTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Users" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ListView Grid.Row="1" ItemsSource="{Binding Users}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Username" Width="120" DisplayMemberBinding="{Binding Username}"/>
                            <GridViewColumn Header="Display Name" Width="150" DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Header="Role" Width="100" DisplayMemberBinding="{Binding Role}"/>
                            <GridViewColumn Header="Active" Width="60" DisplayMemberBinding="{Binding IsActive}"/>
                            <GridViewColumn Header="Last Login" Width="120" DisplayMemberBinding="{Binding LastLoginAt, StringFormat={}{0:dd-MMM-yy HH:mm}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid Visibility="{Binding IsStoresTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Stores" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ListView Grid.Row="1" ItemsSource="{Binding Stores}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Code" Width="80" DisplayMemberBinding="{Binding Code}"/>
                            <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="GSTIN" Width="140" DisplayMemberBinding="{Binding GSTIN}"/>
                            <GridViewColumn Header="City" Width="120" DisplayMemberBinding="{Binding City}"/>
                            <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                            <GridViewColumn Header="Active" Width="60" DisplayMemberBinding="{Binding IsActive}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid Visibility="{Binding IsTerminalsTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Terminals" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ListView Grid.Row="1" ItemsSource="{Binding Terminals}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Mode" Width="80" DisplayMemberBinding="{Binding Mode}"/>
                            <GridViewColumn Header="IP" Width="140" DisplayMemberBinding="{Binding IpAddress}"/>
                            <GridViewColumn Header="Active" Width="60" DisplayMemberBinding="{Binding IsActive}"/>
                            <GridViewColumn Header="Last Heartbeat" Width="140" DisplayMemberBinding="{Binding LastHeartbeat, StringFormat={}{0:dd-MMM-yy HH:mm}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid Visibility="{Binding IsConfigTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Store Configuration" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ListView Grid.Row="1" ItemsSource="{Binding ConfigEntries}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Key" Width="200" DisplayMemberBinding="{Binding Key}"/>
                            <GridViewColumn Header="Value" Width="400" DisplayMemberBinding="{Binding Value}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid Visibility="{Binding IsBackupsTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Cloud Backups" FontSize="14" FontWeight="SemiBold" Foreground="#374151"/>
                    <Button Grid.Column="1" Content="Create Backup" Command="{Binding TriggerBackupCommand}" Background="#1A56DB" Foreground="White" Padding="12,8" BorderThickness="0"/>
                </Grid>
                <ListView Grid.Row="2" ItemsSource="{Binding Backups}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="File Name" Width="250" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Size (KB)" Width="100" DisplayMemberBinding="{Binding FileSizeBytes, StringFormat={}{0:N0}}"/>
                            <GridViewColumn Header="Checksum" Width="200" DisplayMemberBinding="{Binding Checksum}"/>
                            <GridViewColumn Header="Date" Width="140" DisplayMemberBinding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yy HH:mm}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid Visibility="{Binding IsAuditTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Audit Log (Sync History)" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ListView Grid.Row="1" ItemsSource="{Binding AuditLogs}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Direction" Width="80" DisplayMemberBinding="{Binding Direction}"/>
                            <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}"/>
                            <GridViewColumn Header="Items" Width="60" DisplayMemberBinding="{Binding ItemsProcessed}"/>
                            <GridViewColumn Header="Failed" Width="60" DisplayMemberBinding="{Binding ItemsFailed}"/>
                            <GridViewColumn Header="Error" Width="250" DisplayMemberBinding="{Binding ErrorMessage}"/>
                            <GridViewColumn Header="Started" Width="140" DisplayMemberBinding="{Binding StartedAt, StringFormat={}{0:dd-MMM-yy HH:mm}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Foreground="#6B7280" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
