<UserControl x:Class="ShoppingMall.Client.Views.SetupWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F3F4F6">
        <Border Width="500" Padding="30" Background="White"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Shopping Mall POS" FontSize="24" FontWeight="Bold"
                           TextAlignment="Center" Foreground="#1A56DB"/>
                <TextBlock Text="First-Time Setup" FontSize="16" TextAlignment="Center"
                           Foreground="#374151" Margin="0,5,0,25"/>

                <TextBlock Text="{Binding StepTitle}" FontSize="18" FontWeight="SemiBold"
                           Foreground="#111827" Margin="0,0,0,15"/>

                <StackPanel Visibility="{Binding IsStepServer, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Server Address" FontSize="12" Foreground="#374151"/>
                    <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="10" Margin="0,0,0,5"/>
                    <TextBlock Text="e.g., http://192.168.1.100:5000 or http://localhost:5000"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,15"/>

                    <Button Content="Auto-Discover" Command="{Binding AutoDiscoverCommand}"
                            Background="#6B7280" Foreground="White" FontSize="14"
                            Padding="12,8" BorderThickness="0" Margin="0,0,0,5" Height="40"/>
                    <TextBlock Text="{Binding DiscoverStatus}" FontSize="12" Foreground="#6B7280"
                               TextAlignment="Center" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsStepTerminal, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Terminal Name" FontSize="12" Foreground="#374151"/>
                    <TextBox Text="{Binding TerminalName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="10" Margin="0,0,0,5"/>
                    <TextBlock Text="e.g., POS-1, Counter-1, Billing-1"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,15"/>

                    <TextBlock Text="Store Code" FontSize="12" Foreground="#374151"/>
                    <TextBox Text="{Binding StoreCode, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="10" Margin="0,0,0,5"/>
                    <TextBlock Text="Ask your store manager for this code"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,15"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsStepConfirm, Converter={StaticResource BoolToVis}}">
                    <Border Background="#F0FDF4" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Foreground="#059669" Margin="0,0,0,10">Configuration Summary</TextBlock>
                            <TextBlock Text="{Binding ConfirmServerUrl}" FontSize="13" Foreground="#374151"/>
                            <TextBlock Text="{Binding ConfirmTerminalName}" FontSize="13" Foreground="#374151"/>
                            <TextBlock Text="{Binding ConfirmStoreName}" FontSize="13" Foreground="#374151"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Margin="0,0,0,10" Height="4" Foreground="#1A56DB"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12"
                           TextAlignment="Center" Margin="0,0,0,10"/>

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Back" Command="{Binding BackCommand}"
                            Background="Transparent" Foreground="#6B7280" FontSize="14"
                            Padding="15,10" BorderBrush="#D1D5DB" BorderThickness="1"
                            Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="2" Content="{Binding NextButtonText}" Command="{Binding NextCommand}"
                            Background="#1A56DB" Foreground="White" FontSize="16"
                            Padding="15,10" BorderThickness="0" Height="45"
                            Width="{Binding NextButtonWidth}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
