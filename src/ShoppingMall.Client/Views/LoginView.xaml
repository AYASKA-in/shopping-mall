<UserControl x:Class="ShoppingMall.Client.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Background="#F3F4F6">
        <Border Width="400" Padding="30"
                Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Shopping Mall POS" FontSize="24" FontWeight="Bold"
                           TextAlignment="Center" Foreground="#1A56DB"/>
                <TextBlock Text="Sign in to continue" FontSize="14" TextAlignment="Center"
                           Foreground="#6B7280" Margin="0,5,0,20"/>

                <TextBlock Text="Username" FontSize="12" Foreground="#374151" Margin="0,0,0,2"/>
                <TextBox x:Name="UsernameBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16" Padding="10" Margin="0,0,0,10" BorderBrush="#D1D5DB" BorderThickness="1"/>

                <TextBlock Text="PIN" FontSize="12" Foreground="#374151" Margin="0,0,0,2"/>
                <PasswordBox x:Name="PinBox" FontSize="16" Padding="10" Margin="0,0,0,10"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12"
                           TextAlignment="Center" Margin="0,0,0,10"/>

                <Button Content="Sign In" Command="{Binding LoginCommand}" IsDefault="True"
                        Background="#1A56DB" Foreground="White" FontSize="16" Padding="15"
                        BorderThickness="0" Margin="0,10,0,0" Height="50"/>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Margin="0,10,0,0" Height="4" Foreground="#1A56DB"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
