<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package Name="Shopping Mall POS"
             Manufacturer="ShoppingMall"
             Version="1.0.0"
             UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
             Compressed="yes"
             Scope="perMachine">

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" CabinetTemplate="pos{0}.cab" CompressionLevel="high" />

        <Feature Id="ProductFeature" Title="Shopping Mall POS" Level="1">
            <ComponentGroupRef Id="ClientComponents" />
            <ComponentGroupRef Id="ServerComponents" />
            <ComponentGroupRef Id="CloudDashboardComponents" />
            <ComponentGroupRef Id="ShortcutComponents" />
        </Feature>

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="ShoppingMall">
                <Directory Id="ServerDir" Name="Server" />
                <Directory Id="CloudDashboardDir" Name="CloudDashboard" />
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="Shopping Mall POS" />
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder" />

        <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
            <Component Id="AppShortcut" Guid="B1B2C3D4-E5F6-7890-ABCD-EF1234567891">
                <Shortcut Id="AppStartMenuShortcut"
                          Name="Shopping Mall POS"
                          Description="Shopping Mall POS Client"
                          Target="[INSTALLFOLDER]ShoppingMall.Client.exe"
                          WorkingDirectory="INSTALLFOLDER" />
                <Shortcut Id="ServerStartMenuShortcut"
                          Name="Shopping Mall POS Server"
                          Description="Shopping Mall POS Server (runs as Windows Service)"
                          Target="[INSTALLFOLDER]Server\ShoppingMall.Server.exe"
                          WorkingDirectory="INSTALLFOLDER" />
                <Shortcut Id="DesktopShortcut"
                          Name="Shopping Mall POS"
                          Directory="DesktopFolder"
                          Target="[INSTALLFOLDER]ShoppingMall.Client.exe"
                          WorkingDirectory="INSTALLFOLDER" />
                <RegistryValue Root="HKCU"
                               Key="Software\ShoppingMall"
                               Name="installed"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
                <RemoveFolder Id="RemoveAppProgramsFolder" On="uninstall" />
            </Component>
        </ComponentGroup>

        <ComponentGroup Id="ClientComponents" Directory="INSTALLFOLDER">
            <!-- INSERT_CLIENT_FILES_HERE -->
        </ComponentGroup>

        <ComponentGroup Id="ServerComponents" Directory="ServerDir">
            <!-- INSERT_SERVER_FILES_HERE -->
        </ComponentGroup>

        <ComponentGroup Id="CloudDashboardComponents" Directory="CloudDashboardDir">
            <!-- INSERT_CLOUD_FILES_HERE -->
        </ComponentGroup>
    </Package>
</Wix>
