@page "/backups"

<PageTitle>Backups</PageTitle>

<div class="mb-4">
    <h2 class="fw-bold" style="color: #111827;">Backups</h2>
    <p style="color: #6b7280;">AES-256 encrypted cloud backup status</p>
</div>

<div class="card border-0 shadow-sm" style="background: white;">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr style="color: #6b7280;">
                    <th>Store</th>
                    <th>Last Backup</th>
                    <th>Size</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Mumbai - Andheri</td>
                    <td>15 Jul 2026, 11:30 PM</td>
                    <td>256 MB</td>
                    <td><span class="badge bg-success">Success</span></td>
                </tr>
                <tr>
                    <td>Pune - KP</td>
                    <td>15 Jul 2026, 11:30 PM</td>
                    <td>189 MB</td>
                    <td><span class="badge bg-success">Success</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
