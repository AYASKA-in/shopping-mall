@page "/reports"

<PageTitle>Reports</PageTitle>

<div class="mb-4">
    <h2 class="fw-bold" style="color: #111827;">Reports</h2>
    <p style="color: #6b7280;">Sales analysis and GST compliance reports</p>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center" style="background: white; cursor: pointer;">
            <h5 class="fw-bold mb-1" style="color: #1a56db;">Daily Sales</h5>
            <small style="color: #6b7280;">View day-wise sales summary across all stores</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center" style="background: white; cursor: pointer;">
            <h5 class="fw-bold mb-1" style="color: #1a56db;">GST Summary</h5>
            <small style="color: #6b7280;">CGST/SGST/IGST breakup for filing</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center" style="background: white; cursor: pointer;">
            <h5 class="fw-bold mb-1" style="color: #1a56db;">Inventory</h5>
            <small style="color: #6b7280;">Stock movement and low-stock alerts</small>
        </div>
    </div>
</div>
